APP_NAME=stack-ai-rag
APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_TIMEOUT_SECONDS=30
DATA_DIR=data
MAX_UPLOAD_MB=25
MAX_FILES_PER_UPLOAD=10
MAX_PDF_PAGES=500
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=20
CITATION_TOP_K=5
EVIDENCE_SIMILARITY_THRESHOLD=0.35
